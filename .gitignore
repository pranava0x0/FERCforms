# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/

# Downloaded source PDFs — large binaries, re-fetchable from data/listing.json.
# No trailing slash so a `data/raw` symlink (e.g. a worktree pointing at the main
# checkout's PDFs) is ignored too, not just a real directory's contents.
data/raw

# Per-page extracted text — large intermediate, regenerable from the PDF via
# `python -m pipeline.extract`. The structured report.json IS committed.
data/processed/*/text.json

# Standalone patterns CLI output — the site reads the baked docs/data/ version.
data/processed/patterns.json

# Corpus form/industry triage — regenerable via `python -m pipeline.classify`.
data/processed/classification.json

# Secrets (none used today, but never commit these)
.env
.env.local
.env.*
credentials.json
secrets/
*.key
*.pem
*.p12
*.pfx
*.jks
api_keys.json
config.local.json
.aws/
.ssh/
oauth*.json
*_token*
*_secret*
*_password*
.vault-token

# OS
.DS_Store

# Local tooling / editor config (preview launch config, local settings, worktrees).
# Track .claude/skills/ — project skills ship with the repo; ignore everything else.
.claude/*
!.claude/skills/
data/processed/*/report.json
